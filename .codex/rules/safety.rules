# Execution policy rules for fullstack-template

# === FORBIDDEN (always blocked) ===

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Never delete root filesystem",
)

prefix_rule(
    pattern = ["rm", "-rf", "~"],
    decision = "forbidden",
    justification = "Never delete home directory",
)

prefix_rule(
    pattern = ["rm", "-rf", "/*"],
    decision = "forbidden",
    justification = "Never delete root filesystem contents",
)

# === ALLOWED (auto-approved) ===

prefix_rule(pattern = ["pnpm"], decision = "allow")
prefix_rule(pattern = ["npm"], decision = "allow")
prefix_rule(pattern = ["npx"], decision = "allow")

# Allow safe git subcommands (push/reset/clean overridden to prompt below)
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "branch", "add", "commit", "stash", "show", "fetch", "checkout"]],
    decision = "allow",
)

prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["pwd"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["tail"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["rg"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["sort"], decision = "allow")
prefix_rule(pattern = ["uniq"], decision = "allow")
prefix_rule(pattern = ["which"], decision = "allow")
prefix_rule(pattern = ["echo"], decision = "allow")

prefix_rule(
    pattern = [".codex/scripts/pre-commit-check.sh"],
    decision = "allow",
)

# docker compose (non-destructive ops allowed; down/rm overridden to prompt below)
prefix_rule(pattern = ["docker", "compose"], decision = "allow")

# === PROMPT (require confirmation) ===

prefix_rule(
    pattern = ["git", ["push", "reset", "clean"]],
    decision = "prompt",
    justification = "Destructive or remote-modifying git operation",
)

prefix_rule(
    pattern = ["git", "checkout", "."],
    decision = "prompt",
    justification = "Discards working tree changes",
)

prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "File deletion requires confirmation",
)

prefix_rule(
    pattern = ["docker", "compose", ["down", "rm"]],
    decision = "prompt",
    justification = "Stops or removes containers",
)
