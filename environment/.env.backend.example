# Backend Environment Configuration
# Copy this file to .env.backend and fill in your values

# === REQUIRED CONFIGURATION ===

# Database Configuration (Required)
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech:5432/dbname

# Neon API (for CI/CD branch management)
NEON_API_KEY=neon_api_key_your_key_here
NEON_PROJECT_ID=your-neon-project-id

# LLM Providers (at least one required)
# OpenAI - for GPT-5, GPT-4o, O3, O4-mini models
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Anthropic - for Claude Sonnet 4.5, Opus 4.5 models (optional)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini - for Gemini 3, Gemini 2.5 models (optional)
# GEMINI_API_KEY=your-gemini-api-key-here

# Clerk Authentication (Required)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_placeholder_configure_after_deployment

# Google Cloud Storage (Required)
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-bucket-name
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "your-project", "private_key_id": "key-id", "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n", "client_email": "service-account@project.iam.gserviceaccount.com", "client_id": "123456789", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/service-account%40project.iam.gserviceaccount.com"}'

# === APPLICATION CONFIGURATION ===

# Environment
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Redis (for job queue, cache, pub/sub)
# In Docker: redis://redis:6379, locally: redis://localhost:6379
REDIS_URL=redis://redis:6379
# Key prefix for environment isolation (auto-set in CI/CD, empty for local dev)
# REDIS_KEY_PREFIX=dev:

# CORS Configuration (optional - defaults work for local dev)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# === OPTIONAL INTEGRATIONS ===

# Langfuse - LLM Observability (optional)
# Sign up at https://cloud.langfuse.com and create a project
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com  # or https://us.cloud.langfuse.com for US region

# Temporal Cloud - Durable Workflow Execution (optional)
# Sign up at https://cloud.temporal.io and create an API key
# Local dev uses Docker Temporal automatically - no API key needed
# TEMPORAL_API_KEY=eyJhbGciOiJ...your-temporal-cloud-api-key
# TEMPORAL_ADDRESS=us-west-2.aws.api.temporal.io:7233  # Your Temporal Cloud region
# TEMPORAL_NAMESPACE=your-namespace.your-account  # Your Temporal Cloud namespace

# Worker Service - HTTP Activation (Cloud Run only)
# Enables scale-to-zero for workers while maintaining workflow responsiveness.
# When set, backend will call worker's /wakeup endpoint when starting Temporal workflows.
# Not needed for local dev (worker runs continuously in Docker).
# WORKER_URL=https://your-worker-url.run.app