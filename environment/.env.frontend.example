# Frontend Environment Configuration
# Copy this file to .env.frontend and fill in your values

# === REQUIRED CONFIGURATION ===

# Clerk Authentication (Required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Backend API URL
# Not needed for local development - Vite proxy handles /api routes
# Set VITE_BACKEND_URL in production deployments via GitHub Variables

# Environment
NODE_ENV=development

# Feature Flags
VITE_DEBUG=true

# Logging
# Levels: debug (default dev), info, warn, error (default prod), silent
VITE_LOG_LEVEL=debug