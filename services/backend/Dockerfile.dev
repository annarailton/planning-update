# Development Dockerfile for Backend
FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Install system dependencies (including build tools for pygraphviz)
RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    graphviz \
    graphviz-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast Python package management
RUN pip install uv

# Copy shared packages
COPY packages/ /packages/

# Copy application code
COPY services/backend/app/ ./

# Add packages to Python path
ENV PYTHONPATH=/

# Install all dependencies (including dev)
RUN uv sync

# Copy entrypoint script (before switching to non-root user)
COPY services/backend/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Expose port
EXPOSE 8080

# Use entrypoint for migrations
ENTRYPOINT ["docker-entrypoint.sh"]

# Development command with hot reload
CMD ["uv", "run", "--", "python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]