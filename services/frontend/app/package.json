    "@react-three/postprocessing": "3.0.4",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.541.0",
    "motion": "^12.23.26",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^6.28.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "three": "0.182.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
